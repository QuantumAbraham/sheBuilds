---
import { roles } from "../data/spotlights";
import { withBase } from "../data/site";
---

<section class="hero section section-tight">
  <div class="container hero-grid">
    <div class="hero-copy reveal is-visible">
      <span class="eyebrow">Women building the future at TUM</span>
      <h1>Find your people. Build your confidence. Show up in tech.</h1>
      <p class="lead">
        She Builds is a women-in-tech student community at TUM University for events, mentorship, stories, and practical support across software, data, AI, security, product, design, and research.
      </p>
      <div class="btn-row">
        <a class="btn btn-primary" href={withBase("/contact/#join")}>Join the community</a>
        <a class="btn btn-secondary" href={withBase("/events/")}>Attend an event</a>
      </div>
      <div class="hero-notes">
        <span class="meta-pill badge-solid">Semester events</span>
        <span class="meta-pill">Mentor circles</span>
        <span class="meta-pill">Role-model stories</span>
        <span class="meta-pill">Sponsor-ready initiative</span>
      </div>
    </div>

    <div class="hero-panel reveal delay-1">
      <div class="accent-blob hero-blob-one"></div>
      <div class="accent-blob hero-blob-two"></div>
      <div class="sparkle hero-sparkle-one"></div>
      <div class="sparkle hero-sparkle-two"></div>

      <div class="kicker">
        <span>Campus belonging</span>
        <span>Women in computing</span>
        <span>Visible pathways</span>
      </div>

      <div class="hero-stats">
        <article class="stat-card">
          <strong>For every stage</strong>
          <p>Whether you are curious about CS, shipping your first project, or already leading teams.</p>
        </article>
        <article class="stat-card highlight">
          <strong>Built around action</strong>
          <p>Meetups, workshops, hack nights, career talks, mentoring, and tangible next steps.</p>
        </article>
      </div>

      <div class="soft-panel">
        <div class="chip-row">
          {roles.map((role) => (
            <span class="role-pill">{role}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 2rem;
  }

  .hero-grid {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 1.4rem;
    padding: 2rem 0;
  }

  .hero-panel {
    padding: 1.6rem;
    min-height: 32rem;
    display: grid;
    gap: 1.25rem;
    align-content: start;
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.88), rgba(255, 241, 248, 0.82)),
      linear-gradient(145deg, rgba(255, 130, 200, 0.08), rgba(202, 167, 255, 0.14));
  }

  .hero-notes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-stats {
    display: grid;
    gap: 1rem;
  }

  .stat-card {
    padding: 1.1rem;
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(124, 67, 168, 0.1);
  }

  .stat-card strong {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 1.08rem;
  }

  .highlight {
    background: linear-gradient(135deg, rgba(255, 240, 250, 0.94), rgba(245, 239, 255, 0.92));
  }

  .hero-blob-one {
    top: 1rem;
    right: 3rem;
    width: 10rem;
    height: 10rem;
  }

  .hero-blob-two {
    bottom: 2rem;
    left: 1rem;
    width: 7rem;
    height: 7rem;
    animation-duration: 13s;
  }

  .hero-sparkle-one {
    top: 3rem;
    left: 2rem;
  }

  .hero-sparkle-two {
    right: 2.5rem;
    bottom: 5rem;
    animation-delay: 1.2s;
  }

  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-panel {
      min-height: auto;
    }
  }
</style>
