---
import { navigation, siteConfig, withBase } from "../data/site";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-card footer-brand">
      <span class="eyebrow">She Builds</span>
      <h3>More belonging. More role models. More women building tech at TUM.</h3>
      <p>
        A campus community for students who want events, friendships, mentors, and momentum in computing.
      </p>
      <div class="social-list">
        {siteConfig.socialLinks.map((link) => (
          <a class="social-link" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
        ))}
      </div>
    </div>

    <div class="footer-card">
      <h4>Explore</h4>
      <div class="footer-links">
        {navigation.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="footer-card">
      <h4>Get Involved</h4>
      <div class="footer-links">
        <a href={withBase("/events/")}>Attend an event</a>
        <a href={withBase("/contact/#volunteer")}>Volunteer</a>
        <a href={withBase("/contact/#mentor")}>Become a mentor</a>
        <a href={withBase("/partners/#sponsor")}>Partner or sponsor</a>
      </div>
    </div>

    <div class="footer-card">
      <h4>Contact</h4>
      <div class="footer-links">
        <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        <a href="https://lu.ma/shebuilds" target="_blank" rel="noreferrer">Luma events</a>
        <a href="https://linkedin.com/company/she-builds-tum" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>Built for GitHub Pages with Astro.</span>
    <span>{new Date().getFullYear()} She Builds. Sample content ready to customize.</span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 1rem 0 2.5rem;
  }

  .footer-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1.4fr repeat(3, minmax(0, 1fr));
  }

  .footer-card {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(124, 67, 168, 0.1);
    background: rgba(255, 255, 255, 0.74);
    box-shadow: 0 18px 42px rgba(152, 95, 170, 0.12);
  }

  .footer-brand {
    display: grid;
    gap: 1rem;
  }

  .footer-links {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .footer-links a {
    color: var(--text-soft);
    font-weight: 700;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: 1rem;
    padding: 1rem 0 0;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  h4 {
    font-family: "Manrope Variable", system-ui, sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
