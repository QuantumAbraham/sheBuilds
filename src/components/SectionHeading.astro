---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<div class:list={["section-heading", "reveal", align === "center" && "centered"]}>
  <span class="eyebrow">{eyebrow}</span>
  <h2>{title}</h2>
  <p class="lead">{description}</p>
</div>

<style>
  .centered {
    margin-inline: auto;
    text-align: center;
    justify-items: center;
  }
</style>
