---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { siteConfig } from "../data/site";

const contactCards = [
  {
    id: "join",
    title: "Join the community",
    copy: "Introduce yourself, hear about the next event, and get connected to upcoming She Builds opportunities.",
    action: `mailto:${siteConfig.email}?subject=Join%20She%20Builds`
  },
  {
    id: "volunteer",
    title: "Volunteer",
    copy: "Support event production, social media, logistics, check-ins, partnerships, or community growth work.",
    action: `mailto:${siteConfig.email}?subject=Volunteer%20with%20She%20Builds`
  },
  {
    id: "mentor",
    title: "Become a mentor",
    copy: "Share guidance on internships, coursework, projects, confidence, research, or technical career decisions.",
    action: `mailto:${siteConfig.email}?subject=Mentor%20with%20She%20Builds`
  },
  {
    id: "speaker",
    title: "Speak at an event",
    copy: "Bring a story, workshop, panel perspective, or practical session that helps students picture themselves in tech.",
    action: `mailto:${siteConfig.email}?subject=Speak%20with%20She%20Builds`
  },
  {
    id: "sponsor",
    title: "Sponsor or partner",
    copy: "Back the mission with funding, in-kind support, event collaboration, or student-facing opportunities.",
    action: `mailto:${siteConfig.email}?subject=Sponsor%20She%20Builds`
  }
];

const faqs = [
  {
    question: "Do I need to be an experienced developer to join?",
    answer: "No. She Builds is designed to welcome students at many stages, including beginners, explorers, and women still deciding where they fit in computing."
  },
  {
    question: "Is it only for computer science majors?",
    answer: "No. The community includes women in software, data, design, product, research, and adjacent technical paths."
  },
  {
    question: "Can companies or organizations reach out?",
    answer: "Yes. The site includes sponsor and partner pathways because She Builds is also intended to be a credible initiative page for external supporters."
  }
];
---

<BaseLayout
  title="Contact | Join, volunteer, mentor, or sponsor She Builds"
  description="Contact She Builds to join the TUM women-in-tech community, volunteer, mentor students, speak at an event, or explore sponsorship."
>
  <section class="section section-tight">
    <div class="container two-column">
      <div class="card reveal" style="padding: 1.7rem; display: grid; gap: 1rem;">
        <span class="eyebrow">Contact</span>
        <h1>Friendly pathways for students, mentors, volunteers, speakers, and sponsors.</h1>
        <p class="lead">
          Whether you want to join, help, mentor, speak, or partner, this page should make the next step feel clear and inviting.
        </p>
      </div>
      <div class="card reveal delay-1 surface-muted" style="padding: 1.7rem; display: grid; gap: 1rem;">
        <span class="eyebrow">Reach us</span>
        <p>Email: <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></p>
        <div class="social-list">
          {siteConfig.socialLinks.map((link) => (
            <a class="social-link" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Get involved"
        title="Real pathways, not filler"
        description="Each card below can stay as a mailto-based static option or later connect to a form provider without changing the overall page structure."
      />
      <div class="contact-grid">
        {contactCards.map((card, index) => (
          <article class:list={["contact-card", "reveal", `delay-${(index % 4) + 1}`]} id={card.id}>
            <h3>{card.title}</h3>
            <p>{card.copy}</p>
            <a class="link-pill" href={card.action}>{card.title}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-column">
      <article class="form-card reveal">
        <span class="eyebrow">Static-friendly contact form</span>
        <h2>Keep this form structure and wire it later if needed.</h2>
        <p>
          This placeholder keeps the content and design ready for a form service such as Formspree, Basin, or Netlify Forms if the project ever moves away from pure GitHub Pages hosting.
        </p>
        <form>
          <label>
            Name
            <input type="text" name="name" placeholder="Your name" />
          </label>
          <label>
            Email
            <input type="email" name="email" placeholder="you@tum.de" />
          </label>
          <label>
            How would you like to get involved?
            <select name="pathway">
              <option>Join the community</option>
              <option>Volunteer</option>
              <option>Mentor</option>
              <option>Speak</option>
              <option>Sponsor</option>
            </select>
          </label>
          <label>
            Message
            <textarea name="message" rows="5" placeholder="Tell us a little about your interest."></textarea>
          </label>
          <button class="btn btn-primary" type="button">Replace with your form action later</button>
        </form>
      </article>
      <article class="form-card reveal delay-1 surface-muted">
        <span class="eyebrow">FAQs</span>
        <div class="faq-list">
          {faqs.map((item) => (
            <div class="faq-item">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </div>
          ))}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .contact-card,
  .form-card {
    padding: 1.45rem;
    display: grid;
    gap: 1rem;
  }

  .link-pill {
    width: fit-content;
    color: var(--purple);
    background: rgba(255, 255, 255, 0.78);
    border-color: rgba(124, 67, 168, 0.12);
  }

  form {
    display: grid;
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: var(--text);
    font-weight: 700;
  }

  input,
  textarea,
  select {
    width: 100%;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(124, 67, 168, 0.12);
    background: rgba(255, 255, 255, 0.8);
    color: var(--text);
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(124, 67, 168, 0.08);
  }

  @media (max-width: 980px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
